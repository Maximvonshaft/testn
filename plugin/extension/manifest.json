{
  "manifest_version": 3,
  "name": "Zhongxin Maps Lead Assistant",
  "version": "1.9.0",
  "description": "Safe local browser assistant for building-materials lead research on Google Maps. v1.9 adds per-detail watchdog logging and prevents enrichment hangs.",
  "permissions": ["storage", "tabs", "downloads"],
  "host_permissions": ["https://www.google.com/maps/*", "https://maps.google.com/*"],
  "action": {
    "default_title": "ZX Lead Assistant",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*", "https://maps.google.com/*"],
      "js": ["playbooks.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
